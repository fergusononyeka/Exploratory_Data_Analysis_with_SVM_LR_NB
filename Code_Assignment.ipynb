iv class="minimap-slider-horizontal" style="position: absolute; width: 0px; height: 0px;"></div></div></div><div role="presentation" aria-hidden="true" class="blockDecorations-container"></div></div><div data-mprt="2" class="overflowingContentWidgets" style="display: none;"><div widgetid="editor.contrib.resizableContentHoverWidget" style="position: fixed; height: 250px; width: 567px; z-index: 50; display: none; visibility: hidden; max-width: 2400px; top: 385.383px; left: 945.922px;"><div class="monaco-sash vertical" style="left: 565px;"></div><div class="monaco-sash vertical disabled" style="left: -2px;"></div><div class="monaco-sash orthogonal-edge-north horizontal" style="top: -2px;"><div class="orthogonal-drag-handle end"></div></div><div class="monaco-sash orthogonal-edge-south horizontal disabled" style="top: 248px;"><div class="orthogonal-drag-handle end"></div></div><div class="monaco-hover hidden" tabindex="0" role="tooltip" style="max-width: 750.42px; max-height: 250px; --vscode-hover-maxWidth: 750.4200000000001px; width: 567px; height: 250px;"><div class="monaco-scrollable-element " role="presentation" style="position: relative; overflow: hidden;"><div class="monaco-hover-content" style="overflow: hidden; font-size: 14px; line-height: 1.35714; max-width: 750.42px; max-height: 250px; width: 567px; height: 250px;"><div class="hover-row" tabindex="0"><div class="hover-row-contents"><div class="markdown-hover"><div class="hover-contents code-hover-contents"><div class="rendered-markdown"><div data-code="id#70"><span style="font-family: monospace, Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 14px; font-feature-settings: &quot;liga&quot; 0, &quot;calt&quot; 0; font-variation-settings: normal; line-height: 19px; letter-spacing: 0px;"><div class="monaco-tokenized-source"><span class="mtk6">def</span><span class="mtk1"> head(n: </span><span class="mtk6">int</span><span class="mtk1">=</span><span class="mtk7">5</span><span class="mtk1">) -&gt; Self</span></div></span></div></div></div></div><div class="markdown-hover"><div class="hover-contents"><div class="rendered-markdown"><p><a data-href="command:pinDocumentation?%5B%22feature_importance_df.head%22%2C%22%60%60%60python%5Cndef%20head(n%3A%20int%3D5)%20-%3E%20Self%5Cn%60%60%60%5Cn%5CnReturn%20the%20first%20%60n%60%20rows.%5Cn%5CnThis%20function%20returns%20the%20first%20%60n%60%20rows%20for%20the%20object%20based%5Cnon%20position.%20It%20is%20useful%20for%20quickly%20testing%20if%20your%20object%5Cnhas%20the%20right%20type%20of%20data%20in%20it.%5Cn%5CnFor%20negative%20values%20of%20%60n%60%2C%20this%20function%20returns%20all%20rows%20except%20%20%5Cnthe%20last%20%60%7Cn%7C%60%20rows%2C%20equivalent%20to%20%60df%5B%3An%5D%60.%5Cn%5CnIf%20n%20is%20larger%20than%20the%20number%20of%20rows%2C%20this%20function%20returns%20all%20rows.%5Cn%5CnParameters%5Cn----------%5Cnn%20%3A%20int%2C%20default%205%20%20%5Cn%26nbsp%3B%26nbsp%3B%26nbsp%3B%26nbsp%3BNumber%20of%20rows%20to%20select.%5Cn%5CnReturns%5Cn-------%5Cnsame%20type%20as%20caller%20%20%5Cn%26nbsp%3B%26nbsp%3B%26nbsp%3B%26nbsp%3BThe%20first%20%60n%60%20rows%20of%20the%20caller%20object.%5Cn%5CnSee%20Also%5Cn--------%5CnDataFrame.tail%3A%20Returns%20the%20last%20%60n%60%20rows.%5Cn%5CnExamples%5Cn--------%5Cn%60%60%60%5Cn%3E%3E%3E%20df%20%3D%20pd.DataFrame(%7B&#39;animal&#39;%3A%20%5B&#39;alligator&#39;%2C%20&#39;bee&#39;%2C%20&#39;falcon&#39;%2C%20&#39;lion&#39;%2C%5Cn...%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20&#39;monkey&#39;%2C%20&#39;parrot&#39;%2C%20&#39;shark&#39;%2C%20&#39;whale&#39;%2C%20&#39;zebra&#39;%5D%7D)%5Cn%3E%3E%3E%20df%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn5%20%20%20%20%20parrot%5Cn6%20%20%20%20%20%20shark%5Cn7%20%20%20%20%20%20whale%5Cn8%20%20%20%20%20%20zebra%5Cn%60%60%60%5Cn%5CnViewing%20the%20first%205%20lines%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head()%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn%60%60%60%5Cn%5CnViewing%20the%20first%20%60n%60%20lines%20(three%20in%20this%20case)%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head(3)%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn%60%60%60%5Cn%5CnFor%20negative%20values%20of%20%60n%60%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head(-3)%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn5%20%20%20%20%20parrot%5Cn%60%60%60%22%5D" href="https://colab.research.google.com/drive/1g3RJNdiqAKKOKezGAgOmsmLZVSp-JeFB" title="command:pinDocumentation?%5B%22feature_importance_df.head%22%2C%22%60%60%60python%5Cndef%20head(n%3A%20int%3D5)%20-%3E%20Self%5Cn%60%60%60%5Cn%5CnReturn%20the%20first%20%60n%60%20rows.%5Cn%5CnThis%20function%20returns%20the%20first%20%60n%60%20rows%20for%20the%20object%20based%5Cnon%20position.%20It%20is%20useful%20for%20quickly%20testing%20if%20your%20object%5Cnhas%20the%20right%20type%20of%20data%20in%20it.%5Cn%5CnFor%20negative%20values%20of%20%60n%60%2C%20this%20function%20returns%20all%20rows%20except%20%20%5Cnthe%20last%20%60%7Cn%7C%60%20rows%2C%20equivalent%20to%20%60df%5B%3An%5D%60.%5Cn%5CnIf%20n%20is%20larger%20than%20the%20number%20of%20rows%2C%20this%20function%20returns%20all%20rows.%5Cn%5CnParameters%5Cn----------%5Cnn%20%3A%20int%2C%20default%205%20%20%5Cn%26nbsp%3B%26nbsp%3B%26nbsp%3B%26nbsp%3BNumber%20of%20rows%20to%20select.%5Cn%5CnReturns%5Cn-------%5Cnsame%20type%20as%20caller%20%20%5Cn%26nbsp%3B%26nbsp%3B%26nbsp%3B%26nbsp%3BThe%20first%20%60n%60%20rows%20of%20the%20caller%20object.%5Cn%5CnSee%20Also%5Cn--------%5CnDataFrame.tail%3A%20Returns%20the%20last%20%60n%60%20rows.%5Cn%5CnExamples%5Cn--------%5Cn%60%60%60%5Cn%3E%3E%3E%20df%20%3D%20pd.DataFrame(%7B&#39;animal&#39;%3A%20%5B&#39;alligator&#39;%2C%20&#39;bee&#39;%2C%20&#39;falcon&#39;%2C%20&#39;lion&#39;%2C%5Cn...%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20%20&#39;monkey&#39;%2C%20&#39;parrot&#39;%2C%20&#39;shark&#39;%2C%20&#39;whale&#39;%2C%20&#39;zebra&#39;%5D%7D)%5Cn%3E%3E%3E%20df%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn5%20%20%20%20%20parrot%5Cn6%20%20%20%20%20%20shark%5Cn7%20%20%20%20%20%20whale%5Cn8%20%20%20%20%20%20zebra%5Cn%60%60%60%5Cn%5CnViewing%20the%20first%205%20lines%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head()%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn%60%60%60%5Cn%5CnViewing%20the%20first%20%60n%60%20lines%20(three%20in%20this%20case)%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head(3)%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn%60%60%60%5Cn%5CnFor%20negative%20values%20of%20%60n%60%5Cn%5Cn%60%60%60%5Cn%3E%3E%3E%20df.head(-3)%5Cn%20%20%20%20%20%20animal%5Cn0%20%20alligator%5Cn1%20%20%20%20%20%20%20%20bee%5Cn2%20%20%20%20%20falcon%5Cn3%20%20%20%20%20%20%20lion%5Cn4%20%20%20%20%20monkey%5Cn5%20%20%20%20%20parrot%5Cn%60%60%60%22%5D" draggable="false">Open in tab</a>     <a data-href="command:viewSource?%5B%22file%3A%2F%2F%2Fusr%2Flocal%2Flib%2Fpython3.12%2Fdist-packages%2Fpandas%2Fcore%2Fgeneric.py%22%2C%7B%22startLineNumber%22%3A5818%2C%22startColumn%22%3A1%2C%22endLineNumber%22%3A5818%2C%22endColumn%22%3A1%7D%5D" href="https://colab.research.google.com/drive/1g3RJNdiqAKKOKezGAgOmsmLZVSp-JeFB" title="command:viewSource?%5B%22file%3A%2F%2F%2Fusr%2Flocal%2Flib%2Fpython3.12%2Fdist-packages%2Fpandas%2Fcore%2Fgeneric.py%22%2C%7B%22startLineNumber%22%3A5818%2C%22startColumn%22%3A1%2C%22endLineNumber%22%3A5818%2C%22endColumn%22%3A1%7D%5D" draggable="false">View source</a></p></div></div></div><div class="markdown-hover"><div class="hover-contents code-hover-contents"><div class="rendered-markdown"><p>Return the first <code>n</code> rows.</p><p>This function returns the first <code>n</code> rows for the object based
on position. It is useful for quickly testing if your object
has the right type of data in it.</p><p>For negative values of <code>n</code>, this function returns all rows except<br>the last <code>|n|</code> rows, equivalent to <code>df[:n]</code>.</p><p>If n is larger than the number of rows, this function returns all rows.</p><h2>Parameters</h2>
<p>n : int, default 5<br>&nbsp;&nbsp;&nbsp;&nbsp;Number of rows to select.</p><h2>Returns</h2>
<p>same type as caller<br>&nbsp;&nbsp;&nbsp;&nbsp;The first <code>n</code> rows of the caller object.</p><h2>See Also</h2>
<p>DataFrame.tail: Returns the last <code>n</code> rows.</p><h2>Examples</h2>
<div data-code="id#71"><span style="font-family: monospace, Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 14px; font-feature-settings: &quot;liga&quot; 0, &quot;calt&quot; 0; font-variation-settings: normal; line-height: 19px; letter-spacing: 0px;"><div class="monaco-tokenized-source"><span class="mtk1">&gt;&gt;&gt; df = pd.DataFrame({</span><span class="mtk21">'animal'</span><span class="mtk1">: [</span><span class="mtk21">'alligator'</span><span class="mtk1">, </span><span class="mtk21">'bee'</span><span class="mtk1">, </span><span class="mtk21">'falcon'</span><span class="mtk1">, </span><span class="mtk21">'lion'</span><span class="mtk1">,</span><br><span class="mtk1">...                    </span><span class="mtk21">'monkey'</span><span class="mtk1">, </span><span class="mtk21">'parrot'</span><span class="mtk1">, </span><span class="mtk21">'shark'</span><span class="mtk1">, </span><span class="mtk21">'whale'</span><span class="mtk1">, </span><span class="mtk21">'zebra'</span><span class="mtk1">]})</span><br><span class="mtk1">&gt;&gt;&gt; df</span><br><span class="mtk1">      animal</span><br><span class="mtk12">0</span><span class="mtk1">  alligator</span><br><span class="mtk12">1</span><span class="mtk1">        bee</span><br><span class="mtk12">2</span><span class="mtk1">     falcon</span><br><span class="mtk12">3</span><span class="mtk1">       lion</span><br><span class="mtk12">4</span><span class="mtk1">     monkey</span><br><span class="mtk12">5</span><span class="mtk1">     parrot</span><br><span class="mtk12">6</span><span class="mtk1">      shark</span><br><span class="mtk12">7</span><span class="mtk1">      whale</span><br><span class="mtk12">8</span><span class="mtk1">      zebra</span></div></span></div><p>Viewing the first 5 lines</p><div data-code="id#72"><span style="font-family: monospace, Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 14px; font-feature-settings: &quot;liga&quot; 0, &quot;calt&quot; 0; font-variation-settings: normal; line-height: 19px; letter-spacing: 0px;"><div class="monaco-tokenized-source"><span class="mtk1">&gt;&gt;&gt; df.head()</span><br><span class="mtk1">      animal</span><br><span class="mtk12">0</span><span class="mtk1">  alligator</span><br><span class="mtk12">1</span><span class="mtk1">        bee</span><br><span class="mtk12">2</span><span class="mtk1">     falcon</span><br><span class="mtk12">3</span><span class="mtk1">       lion</span><br><span class="mtk12">4</span><span class="mtk1">     monkey</span></div></span></div><p>Viewing the first <code>n</code> lines (three in this case)</p><div data-code="id#73"><span style="font-family: monospace, Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 14px; font-feature-settings: &quot;liga&quot; 0, &quot;calt&quot; 0; font-variation-settings: normal; line-height: 19px; letter-spacing: 0px;"><div class="monaco-tokenized-source"><span class="mtk1">&gt;&gt;&gt; df.head(</span><span class="mtk12">3</span><span class="mtk1">)</span><br><span class="mtk1">      animal</span><br><span class="mtk12">0</span><span class="mtk1">  alligator</span><br><span class="mtk12">1</span><span class="mtk1">        bee</span><br><span class="mtk12">2</span><span class="mtk1">     falcon</span></div></span></div><p>For negative values of <code>n</code></p><div data-code="id#74"><span style="font-family: monospace, Consolas, &quot;Courier New&quot;, monospace; font-weight: normal; font-size: 14px; font-feature-settings: &quot;liga&quot; 0, &quot;calt&quot; 0; font-variation-settings: normal; line-height: 19px; letter-spacing: 0px;"><div class="monaco-tokenized-source"><span class="mtk1">&gt;&gt;&gt; df.head(</span><span class="mtk12">-3</span><span class="mtk1">)</span><br><span class="mtk1">      animal</span><br><span class="mtk12">0</span><span class="mtk1">  alligator</span><br><span class="mtk12">1</span><span class="mtk1">        bee</span><br><span class="mtk12">2</span><span class="mtk1">     falcon</span><br><span class="mtk12">3</span><span class="mtk1">       lion</span><br><span class="mtk12">4</span><span class="mtk1">     monkey</span><br><span class="mtk12">5</span><span class="mtk1">     parrot</span></div></span></div></div></div></div></div></div></div><div role="presentation" aria-hidden="true" class="invisible scrollbar horizontal" style="position: absolute; width: 557px; height: 10px; left: 0px; bottom: 0px;"><div class="slider" style="position: absolute; top: 0px; left: 0px; height: 10px; transform: translate3d(0px, 0px, 0px); contain: strict; width: 557px;"></div></div><div role="presentation" aria-hidden="true" class="invisible scrollbar vertical fade" style="position: absolute; width: 10px; height: 250px; right: 0px; top: 0px;"><div class="slider" style="position: absolute; top: 0px; left: 0px; width: 10px; transform: translate3d(0px, 0px, 0px); contain: strict; height: 51px;"></div></div><div class="shadow"></div><div class="shadow"></div><div class="shadow"></div></div></div></div></div><div data-mprt="5" class="overflowingOverlayWidgets"></div><div class=".in-cell-overflowing"><div widgetid="editor.contrib.quickInputWidget" style="position: absolute; right: 50%; top: 0px;"></div></div></div></div></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
