</pre><pre class="monaco-colorized colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk19">from</span><span class="mtk1">&nbsp;sklearn.naive_bayes&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;GaussianNB</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;sklearn.metrics&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;accuracy_score</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Initialize&nbsp;and&nbsp;train&nbsp;the&nbsp;Naive&nbsp;Bayes&nbsp;model</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"\nTraining&nbsp;Naive&nbsp;Bayes&nbsp;model..."</span><span class="mtk1">)</span></span><br><span><span class="mtk1">nb_model&nbsp;=&nbsp;GaussianNB()</span></span><br><span><span class="mtk1">nb_model.fit(X_train,&nbsp;y_train)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Make&nbsp;predictions&nbsp;on&nbsp;the&nbsp;test&nbsp;set</span></span><br><span><span class="mtk1">y_pred_nb&nbsp;=&nbsp;nb_model.predict(X_test)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Evaluate&nbsp;the&nbsp;accuracy&nbsp;of&nbsp;the&nbsp;Naive&nbsp;Bayes&nbsp;model</span></span><br><span><span class="mtk1">accuracy_nb&nbsp;=&nbsp;accuracy_score(y_test,&nbsp;y_pred_nb)</span></span><br><span><span></span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Accuracy&nbsp;of&nbsp;Naive&nbsp;Bayes&nbsp;model:&nbsp;</span><span class="mtk1">{accuracy_nb</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$351812512$-->Start coding or <span tabindex="0" role="button" class="link">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
